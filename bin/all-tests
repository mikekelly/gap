#!/usr/bin/env bash
# Run all GAP tests: unit/integration tests + Docker horizontal smoke tests
#
# Usage:
#   bin/all-tests          # Run everything
#   bin/all-tests cargo    # Run only cargo tests
#   bin/all-tests docker   # Run only Docker horizontal smoke tests

set -e

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BOLD='\033[1m'
NC='\033[0m'

REPO_DIR="$(cd "$(dirname "$0")/.." && pwd)"
cd "$REPO_DIR"

phase() {
    echo ""
    echo -e "${BOLD}═══════════════════════════════════════════════════${NC}"
    echo -e "${BOLD}  $1${NC}"
    echo -e "${BOLD}═══════════════════════════════════════════════════${NC}"
    echo ""
}

run_cargo_tests() {
    phase "Phase 1: Cargo workspace tests"

    cargo test --workspace 2>&1
    echo ""
    echo -e "${GREEN}Cargo tests passed.${NC}"
}

run_docker_horizontal_tests() {
    phase "Phase 2: Docker horizontal mode smoke tests (Postgres)"

    # Clean up any previous run
    docker compose --profile test-horizontal down -v --remove-orphans 2>/dev/null || true

    # Build and run horizontal mode tests
    echo "Building and starting services (postgres, gap-server-horizontal, test-runner)..."
    docker compose --profile test-horizontal up \
        --build \
        --abort-on-container-exit \
        --exit-code-from test-runner-horizontal

    EXIT_CODE=$?

    # Clean up
    echo ""
    echo "Cleaning up Docker containers..."
    docker compose --profile test-horizontal down -v --remove-orphans 2>/dev/null || true

    if [ $EXIT_CODE -ne 0 ]; then
        echo -e "${RED}Docker horizontal smoke tests failed (exit code $EXIT_CODE).${NC}"
        return $EXIT_CODE
    fi

    echo ""
    echo -e "${GREEN}Docker horizontal smoke tests passed.${NC}"
}

# Parse arguments
MODE="${1:-all}"

case "$MODE" in
    cargo)
        run_cargo_tests
        ;;
    docker)
        run_docker_horizontal_tests
        ;;
    all)
        run_cargo_tests
        run_docker_horizontal_tests
        ;;
    *)
        echo "Usage: $0 [cargo|docker|all]"
        exit 1
        ;;
esac

phase "All tests passed"
